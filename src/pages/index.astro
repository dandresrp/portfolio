---
import Layout from '../layouts/Layout.astro';
---

<Layout locale="es">
  <div style="min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1.5rem; padding:2rem;">
    <h1 style="font-family:'Instrument Serif',serif; font-size:3rem; color:var(--text);">
      Diego Rios
    </h1>
    <p style="font-family:'DM Sans',sans-serif; color:var(--text-muted); font-size:1.125rem;">
      Fase 1 — Scaffold completo. Fonts, tema y Tailwind listos.
    </p>
    <p style="font-family:'DM Sans',sans-serif; color:var(--text-faint); font-size:0.875rem;">
      Tema activo: <strong id="theme-label" style="color:var(--accent)">—</strong>
    </p>
    <button
      id="theme-toggle"
      style="
        padding: 0.5rem 1.25rem;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: transparent;
        color: var(--text);
        font-family: 'DM Sans', sans-serif;
        font-size: 0.875rem;
        cursor: pointer;
        transition: border-color 250ms ease, color 250ms ease;
      "
    >
      Alternar tema
    </button>
  </div>

  <script>
    const toggle = document.getElementById('theme-toggle');
    const label  = document.getElementById('theme-label');
    const html   = document.documentElement;

    function updateLabel() {
      if (label) label.textContent = html.classList.contains('dark') ? 'dark' : 'light';
    }

    updateLabel();

    toggle?.addEventListener('click', () => {
      const isDark = html.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateLabel();
    });
  </script>
</Layout>
