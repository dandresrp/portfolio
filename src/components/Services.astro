---
import SectionHeading from './SectionHeading.astro';
import { getTranslation, toLocale } from '../i18n/ui';

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;
const t = getTranslation(toLocale(locale));
const { services } = t;
---

<section
  id={locale === 'en' ? 'services' : 'servicios'}
  class="services"
  aria-label={services.label}
>
  <div class="services__inner">

    <SectionHeading
      label={services.label}
      title={services.title}
    />

    <ol class="services__list" role="list">
      {services.items.map((item) => (
        <li class="services__item reveal">
          <span class="services__number" aria-hidden="true">{item.number}</span>
          <div class="services__content">
            <h3 class="services__title">{item.title}</h3>
            <p class="services__description">{item.description}</p>
          </div>
          <span class="services__arrow" aria-hidden="true">→</span>
        </li>
      ))}
    </ol>

  </div>
</section>

<style>
  .services {
    padding: 6rem 1.5rem;
    background-color: var(--bg-alt);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .services__inner {
    max-width: 760px;
    margin: 0 auto;
  }

  /* ── List ──────────────────────────────────────────────────────── */
  .services__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  /* ── Item ──────────────────────────────────────────────────────── */
  .services__item {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    align-items: start;
    gap: 1.25rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
    transition: background-color 200ms ease;
    cursor: default;
  }

  .services__item:first-child {
    border-top: 1px solid var(--border);
  }

  .services__item:hover .services__title {
    color: var(--accent);
  }

  .services__item:hover .services__arrow {
    transform: translateX(4px);
    color: var(--accent);
  }

  /* ── Number ────────────────────────────────────────────────────── */
  .services__number {
    font-family: var(--font-serif);
    font-size: 0.8125rem;
    font-style: italic;
    color: var(--text-faint);
    padding-top: 0.2rem;
    letter-spacing: 0.02em;
  }

  /* ── Content ───────────────────────────────────────────────────── */
  .services__content {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .services__title {
    font-family: var(--font-serif);
    font-size: 1.1875rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--text);
    margin: 0;
    line-height: 1.3;
    transition: color 200ms ease;
  }

  .services__description {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-muted);
    margin: 0;
  }

  /* ── Arrow ─────────────────────────────────────────────────────── */
  .services__arrow {
    font-size: 1rem;
    color: var(--text-faint);
    padding-top: 0.25rem;
    transition: transform 200ms ease, color 200ms ease;
    flex-shrink: 0;
  }
</style>
