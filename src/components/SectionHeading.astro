---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { label, title, subtitle, align = 'left' } = Astro.props;
---

<div class:list={['section-heading', `section-heading--${align}`, 'reveal']}>
  {label && (
    <p class="section-heading__label">
      <span class="section-heading__label-line" aria-hidden="true"></span>
      {label}
    </p>
  )}
  <h2 class="section-heading__title">{title}</h2>
  {subtitle && (
    <p class="section-heading__subtitle">{subtitle}</p>
  )}
</div>

<style>
  .section-heading {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 3.5rem;
  }

  .section-heading--center {
    align-items: center;
    text-align: center;
  }

  /* ── Label ─────────────────────────────────────────────────────── */
  .section-heading__label {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0;
  }

  .section-heading--center .section-heading__label {
    justify-content: center;
  }

  .section-heading__label-line {
    display: block;
    width: 24px;
    height: 1px;
    background-color: var(--accent);
    flex-shrink: 0;
    opacity: 0.6;
  }

  /* ── Title ─────────────────────────────────────────────────────── */
  .section-heading__title {
    font-family: var(--font-serif);
    font-size: clamp(1.875rem, 3.5vw, 2.75rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: 0;
  }

  /* ── Subtitle ──────────────────────────────────────────────────── */
  .section-heading__subtitle {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--text-muted);
    max-width: 560px;
    margin: 0;
  }

  .section-heading--center .section-heading__subtitle {
    margin-inline: auto;
  }
</style>
