---
import SectionHeading from './SectionHeading.astro';
import { getTranslation, toLocale } from '../i18n/ui';

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;
const t = getTranslation(toLocale(locale));
const { about } = t;
---

<section
  id={locale === 'en' ? 'about' : 'sobre-mi'}
  class="about"
  aria-label={about.label}
>
  <div class="about__inner">

    <SectionHeading
      label={about.label}
      title={about.title}
    />

    <div class="about__content reveal">
      <!-- Decorative left bar -->
      <span class="about__bar" aria-hidden="true"></span>

      <div class="about__text">
        {about.paragraphs.map((p) => (
          <p class="about__paragraph">{p}</p>
        ))}
      </div>
    </div>

    <!-- Stats row -->
    <dl class="about__stats reveal-stagger">
      <div class="about__stat">
        <dt class="about__stat-label">
          {locale === 'es' ? 'Experiencia' : 'Experience'}
        </dt>
        <dd class="about__stat-value">1.5 {locale === 'es' ? 'años' : 'years'}</dd>
      </div>
      <div class="about__stat">
        <dt class="about__stat-label">
          {locale === 'es' ? 'Proyectos' : 'Projects'}
        </dt>
        <dd class="about__stat-value">5+</dd>
      </div>
      <div class="about__stat">
        <dt class="about__stat-label">
          {locale === 'es' ? 'Enfoque' : 'Focus'}
        </dt>
        <dd class="about__stat-value">Backend · Mobile</dd>
      </div>
    </dl>

  </div>
</section>

<style>
  .about {
    padding: 6rem 1.5rem;
    background-color: var(--bg-alt);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .about__inner {
    max-width: 760px;
    margin: 0 auto;
  }

  /* ── Content block with decorative bar ────────────────────────── */
  .about__content {
    display: flex;
    gap: 2rem;
    margin-bottom: 3.5rem;
  }

  .about__bar {
    display: block;
    flex-shrink: 0;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--accent),
      transparent
    );
    border-radius: 2px;
    min-height: 100%;
    opacity: 0.5;
  }

  /* ── Paragraphs ────────────────────────────────────────────────── */
  .about__text {
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }

  .about__paragraph {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--text-muted);
    margin: 0;
  }

  .about__paragraph:first-child {
    font-size: 1.1875rem;
    color: var(--text);
    font-weight: 300;
  }

  /* ── Stats ─────────────────────────────────────────────────────── */
  .about__stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background-color: var(--border);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    margin: 0;
  }

  @media (min-width: 640px) {
    .about__stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .about__stat {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1.25rem 1.5rem;
    background-color: var(--bg-card);
  }

  .about__stat-label {
    font-size: 0.7375rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .about__stat-value {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--text);
    letter-spacing: -0.01em;
  }
</style>
