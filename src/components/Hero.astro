---
import { getTranslation, toLocale } from '../i18n/ui';

interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;
const t = getTranslation(toLocale(locale));
const { hero } = t;
---

<section class="hero" aria-label={locale === 'es' ? 'Presentación' : 'Introduction'}>
  <div class="hero__inner">

    <!-- Eyebrow label -->
    <p class="hero__eyebrow reveal">
      <span class="hero__eyebrow-dot" aria-hidden="true"></span>
      {locale === 'es' ? 'Abierto a nuevas conexiones' : 'Open to new connections'}
    </p>

    <!-- Main heading -->
    <h1 class="hero__title reveal">
      {hero.title}
      <br />
      <em class="hero__title-em">{hero.subtitle}</em>
    </h1>

    <!-- Description -->
    <p class="hero__description reveal">
      {hero.description}
    </p>

    <!-- Tech stack -->
    <p class="hero__stack reveal" aria-label={locale === 'es' ? 'Tecnologías principales' : 'Core technologies'}>
      {hero.techStack.map((tech, i) => (
        <>
          <span class="hero__stack-item">{tech}</span>
          {i < hero.techStack.length - 1 && (
            <span class="hero__stack-sep" aria-hidden="true">·</span>
          )}
        </>
      ))}
    </p>

    <!-- CTAs -->
    <div class="hero__ctas reveal">
      <a href={hero.cta.primaryHref} class="btn btn--primary">
        {hero.cta.primary}
      </a>
      <a href={hero.cta.secondaryHref} class="btn btn--outline">
        {hero.cta.secondary}
      </a>
    </div>

  </div>
</section>

<style>
  /* ── Section shell ─────────────────────────────────────────────── */
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding: 7rem 1.5rem 5rem;
  }

  .hero__inner {
    max-width: 760px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  /* ── Eyebrow ───────────────────────────────────────────────────── */
  .hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin: 0;
  }

  .hero__eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--accent);
    flex-shrink: 0;
    /* pulse animation */
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(0.8); }
  }

  /* ── Title ─────────────────────────────────────────────────────── */
  .hero__title {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--text);
    margin: 0;
  }

  .hero__title-em {
    font-style: italic;
    color: var(--text-muted);
  }

  /* ── Description ───────────────────────────────────────────────── */
  .hero__description {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--text-muted);
    max-width: 560px;
    margin: 0;
  }

  /* ── Tech stack ────────────────────────────────────────────────── */
  .hero__stack {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem 0.5rem;
    margin: 0;
  }

  .hero__stack-item {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-faint);
    letter-spacing: 0.02em;
  }

  .hero__stack-sep {
    color: var(--border-hover);
    font-size: 0.875rem;
    line-height: 1;
  }

  /* ── CTAs ──────────────────────────────────────────────────────── */
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    padding-top: 0.5rem;
  }

  /* ── Buttons ───────────────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.65rem 1.5rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition:
      background-color 200ms ease,
      color 200ms ease,
      border-color 200ms ease,
      transform 150ms ease;
    cursor: pointer;
  }

  .btn:active { transform: translateY(1px); }

  .btn--primary {
    background-color: var(--text);
    color: var(--bg);
    border: 1px solid var(--text);
  }
  .btn--primary:hover {
    background-color: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .btn--outline {
    background-color: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border);
  }
  .btn--outline:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }

  /* ── Reveal animation delays ───────────────────────────────────── */
  .hero__inner .reveal:nth-child(1) { animation-delay: 0ms; }
  .hero__inner .reveal:nth-child(2) { animation-delay: 80ms; }
  .hero__inner .reveal:nth-child(3) { animation-delay: 160ms; }
  .hero__inner .reveal:nth-child(4) { animation-delay: 240ms; }
  .hero__inner .reveal:nth-child(5) { animation-delay: 320ms; }
</style>
