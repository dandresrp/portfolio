---
import TechBadge from './TechBadge.astro';
import type { Project } from '../i18n/projects';

interface Props {
  project: Project;
  locale?: string;
}

const { project, locale = 'es' } = Astro.props;
const { title, description, tasks, technologies, impact } = project;
---

<article class="project-card reveal">

  <!-- Header -->
  <header class="project-card__header">
    <h3 class="project-card__title">{title}</h3>
    <p class="project-card__description">{description}</p>
  </header>

  <!-- Tasks list -->
  <div class="project-card__section">
    <p class="project-card__section-label">
      {locale === 'es' ? 'Qué hice' : 'What I did'}
    </p>
    <ul class="project-card__tasks" role="list">
      {tasks.map((task) => (
        <li class="project-card__task">
          <span class="project-card__task-dot" aria-hidden="true"></span>
          {task}
        </li>
      ))}
    </ul>
  </div>

  <!-- Footer: tech + impact -->
  <footer class="project-card__footer">

    <!-- Tech badges -->
    <div class="project-card__tech" aria-label={locale === 'es' ? 'Tecnologías' : 'Technologies'}>
      {technologies.map((tech) => (
        <TechBadge label={tech} />
      ))}
    </div>

    <!-- Impact (optional) -->
    {impact && (
      <div class="project-card__impact">
        <span class="project-card__impact-label" aria-hidden="true">↗</span>
        <p class="project-card__impact-text">{impact}</p>
      </div>
    )}

  </footer>

</article>

<style>
  /* ── Card shell ────────────────────────────────────────────────── */
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    background-color: var(--bg-card);
    transition:
      border-color 250ms ease,
      transform 250ms ease,
      box-shadow 250ms ease;
  }

  .project-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  }

  :global(.dark) .project-card:hover {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
  }

  /* ── Header ────────────────────────────────────────────────────── */
  .project-card__header {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .project-card__title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--text);
    margin: 0;
    line-height: 1.25;
  }

  .project-card__description {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--text-muted);
    margin: 0;
  }

  /* ── Tasks section ─────────────────────────────────────────────── */
  .project-card__section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .project-card__section-label {
    font-size: 0.7375rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin: 0;
  }

  .project-card__tasks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .project-card__task {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--text-muted);
  }

  .project-card__task-dot {
    display: block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: var(--accent);
    flex-shrink: 0;
    margin-top: 0.45em;
    opacity: 0.7;
  }

  /* ── Footer ────────────────────────────────────────────────────── */
  .project-card__footer {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }

  /* ── Tech badges ───────────────────────────────────────────────── */
  .project-card__tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  /* ── Impact ────────────────────────────────────────────────────── */
  .project-card__impact {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .project-card__impact-label {
    font-size: 0.875rem;
    color: var(--accent);
    flex-shrink: 0;
    line-height: 1;
  }

  .project-card__impact-text {
    font-size: 0.8375rem;
    line-height: 1.55;
    color: var(--text-faint);
    font-style: italic;
    margin: 0;
  }
</style>
